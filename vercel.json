{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/welcome",
      "destination": "/welcome.html"
    },
    {
      "source": "/",
      "destination": "/welcome.html"
    }
  ]
}
